<?php
/**
 * @var \Omeka\View\Renderer\PhpRenderer $this
 * @var \Omeka\Api\Representation\SiteRepresentation $site
 * @var \Omeka\Api\Representation\PageRepresentation $page
 */
$escape = $this->plugin('escapeHtml');
$siteTitle = $site->title();
$this->htmlElement('html')->setAttribute('lang', $this->lang());
$this->headMeta()->setCharset('utf-8');
$this->headMeta()->appendName('viewport', 'width=device-width, initial-scale=1');
$this->headTitle($siteTitle)->setSeparator(' · ');
$this->headTitle()->append($this->setting('installation_title', 'Omeka S'));

// Bootstrap 5 CSS
$this->headLink()->prependStylesheet('https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css');
// Font Awesome
$this->headLink()->appendStylesheet('https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css');
// Custom CSS
$this->headLink()->appendStylesheet($this->assetUrl('css/style.css'));

// Bootstrap 5 JS
$this->headScript()->appendFile('https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js');
?>
<?php echo $this->doctype(); ?>
<?php echo $this->htmlElement('html'); ?>
    <head>
        <?php echo $this->headMeta(); ?>
        <?php echo $this->headTitle(); ?>
        <?php echo $this->headLink(); ?>
        <?php echo $this->headStyle(); ?>
        <?php echo $this->headScript(); ?>
    </head>
    <?php echo $this->htmlElement('body'); ?>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
            <div class="container">
                <a class="navbar-brand" href="<?php echo $site->url(); ?>">
                    <?php echo $escape($siteTitle); ?>
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <?php echo $site->publicNav()->menu()->renderMenu(null, [
                        'ulClass' => 'navbar-nav ms-auto',
                        'liClass' => 'nav-item',
                        'aClass' => 'nav-link',
                    ]); ?>
                </div>
            </div>
        </nav>

        <main class="container mb-5">
            <?php echo $this->content; ?>
        </main>

        <footer class="bg-light py-4 border-top mt-auto">
            <div class="container text-center">
                <p class="mb-0 text-muted">&copy; <?php echo date('Y'); ?> <?php echo $escape($siteTitle); ?> - DDA UNT</p>
                <small class="text-muted">Desarrollado bajo normas ISAD(G), ISAAR(CPF), ISDIAH, FIAF y FIAT.</small>
            </div>
        </footer>
    </body>
</html>
